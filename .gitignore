__pycache__/
*.pyc
.pytest_cache/
.venv/
venv/

# Generated outputs - these get REGENERATED by the pipeline, so we don't
# want to accumulate history bloat by committing every run. We'll decide
# later whether the GitHub Actions job commits the latest output/*.geojson
# back to the repo (simple, but grows repo size over time) or pushes it
# somewhere else (e.g. a tiny object store) instead.
output/*.geojson
tests/demo_output.png
tests/demo_output.geojson

# Large cached terrain/DEM files - regenerate locally, don't commit
data/terrain/*.tif
data/terrain/*.tiff

.DS_Store
