__pycache__/
*.pyc
.pytest_cache/
.venv/
venv/

# Generated outputs - ignored by default so ad-hoc local/test runs
# don't clutter the repo, EXCEPT ifr_latest.geojson, which
# generate_ifr.yml deliberately commits and overwrites on schedule --
# that's the file the web app actually serves. Without the negation
# line below, 'git add' would silently refuse to stage it (matches
# .gitignore), the workflow's commit step would never have anything
# staged, and the site would never update.
output/*.geojson
!output/ifr_latest.geojson

# Large cached terrain/DEM files - regenerate locally, don't commit
data/terrain/*.tif
data/terrain/*.tiff

.DS_Store
